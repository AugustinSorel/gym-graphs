{
  "name": "gym-graphs",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "lint": "tsc --build --noemit",
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "web": "pnpm --filter @gym-graphs/web",
    "api": "pnpm --filter @gym-graphs/api",
    "shared": "pnpm --filter @gym-graphs/shared",
    "docker:api:build": "docker build --target api --tag gym_graphs_api .",
    "docker:web:build": "docker build --target web --tag gym_graphs_web .",
    "docker:migration:build": "docker build --target migration --tag gym_graphs_migration .",
    "docker:migration:run": "docker run --name gym_graphs_migration --rm --env-file=./apps/api/.env --network gym-graphs_db gym_graphs_migration",
    "docker:api:run": "docker run -p 5000:5000 --name gym_graphs_api --rm --env-file=./apps/api/.env --network gym-graphs_db gym_graphs_api",
    "docker:web:run": "docker run -p 3000:3000 --name gym_graphs_web --rm gym_graphs_web"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.17.1",
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
