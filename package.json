{
  "name": "gym-graphs",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "lint": "tsc --build --noemit",
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "web": "pnpm --filter @gym-graphs/web",
    "api": "pnpm --filter @gym-graphs/api",
    "db": "pnpm --filter @gym-graphs/db",
    "schemas": "pnpm --filter @gym-graphs/schemas",
    "contracts": "pnpm --filter @gym-graphs/contracts",
    "errors": "pnpm --filter @gym-graphs/errors",
    "middlware": "pnpm --filter @gym-graphs/middlware",
    "docker:api:build": "docker build --target api --tag gym_graphs_api .",
    "docker:api:run": "docker run -p 5000:5000 --env-file=./apps/api/.env --name gym_graphs_api --rm gym_graphs_api",
    "docker:migration:build": "docker build --target migration --tag gym_graphs_migration .",
    "docker:migration:run": "docker run --env-file=./apps/api/.env --name gym_graphs_migration --rm gym_graphs_migration"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.17.1",
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
