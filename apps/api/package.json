{
  "name": "@gym-graphs/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=./.env ./src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "db:bash": "docker exec -it gym_graphs_db bash -c 'psql -U postgres -d gym_graphs'",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.17.1",
  "devDependencies": {
    "@types/node": "^24.9.1",
    "@types/pg": "^8.15.6",
    "tsup": "^8.5.0",
    "tsx": "^4.21.0"
  },
  "dependencies": {
    "@aws-sdk/client-ses": "^3.1009.0",
    "@effect/platform": "^0.94.5",
    "@effect/platform-node": "^0.104.1",
    "@effect/sql": "^0.49.0",
    "@effect/sql-pg": "^0.50.3",
    "@gym-graphs/shared": "workspace:*",
    "drizzle-kit": "1.0.0-beta.17-67b1795",
    "drizzle-orm": "1.0.0-beta.17-67b1795",
    "effect": "^3.19.19",
    "pg": "^8.16.3"
  }
}
